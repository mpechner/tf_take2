---
- name: Configure RKE2 Agent Nodes
  hosts: localhost
  become: true
  gather_facts: true
  vars:
    cluster_name: "${cluster_name}"
    docker_version: "${docker_version}"
    rke_version: "${rke_version}"
    rke2_version: "${rke2_version}"
    awscli_version: "${awscli_version}"
    region: "${aws_region}"
    server_endpoint: "${server_endpoint}"

  tasks:
    - name: Update apt cache
      apt:
        update_cache: yes
        upgrade: safe

    - name: Install prerequisites
      apt:
        name:
          - curl
          - python3
          - python3-pip
          - python3-venv
          - unzip
        state: present
        update_cache: yes

    - name: Remove broken awscli apt package if present
      apt:
        name: awscli
        state: absent

    - name: Install AWS CLI v2
      shell: |
        INSTALLED_VERSION=$(aws --version 2>&1 | grep -oP 'aws-cli/\K[0-9.]+' || echo "none")
        if [ "$INSTALLED_VERSION" != "${awscli_version}" ]; then
          WORK_DIR=$(mktemp -d)
          trap "rm -rf '$WORK_DIR'" EXIT
          cd "$WORK_DIR"
          curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-x86_64-${awscli_version}.zip"        -o "awscliv2.zip"
          curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-x86_64-${awscli_version}.zip.sha256" -o "awscliv2.zip.sha256"
          sha256sum --check awscliv2.zip.sha256
          unzip -q -o awscliv2.zip
          ./aws/install --update
        fi
      args:
        creates: /usr/local/bin/aws

    - name: Install RKE2 agent
      shell: |
        WORK_DIR=$(mktemp -d)
        trap "rm -rf '$WORK_DIR'" EXIT
        cd "$WORK_DIR"
        curl -fsSL "https://github.com/rancher/rke2/releases/download/${rke2_version}/sha256sum-amd64.txt" -o sha256sum-amd64.txt
        curl -fsSL https://get.rke2.io -o install.sh
        EXPECTED=$(grep "install.sh" sha256sum-amd64.txt | awk '{print $1}' || true)
        if [ -n "$EXPECTED" ]; then
          echo "$EXPECTED  install.sh" | sha256sum --check || { echo "RKE2 installer checksum verification failed"; exit 1; }
        fi
        chmod 700 install.sh
        INSTALL_RKE2_TYPE=agent INSTALL_RKE2_VERSION="${rke2_version}" sh install.sh
      args:
        creates: /usr/local/bin/rke2

    - name: Configure system limits
      lineinfile:
        path: /etc/security/limits.conf
        line: "{{ item }}"
        state: present
      loop:
        - "* soft nofile 65536"
        - "* hard nofile 65536"
        - "* soft nproc 32768"
        - "* hard nproc 32768"

    - name: Configure sysctl parameters
      copy:
        dest: /etc/sysctl.d/99-kubernetes-cri.conf
        content: |
          net.bridge.bridge-nf-call-iptables  = 1
          net.ipv4.ip_forward                 = 1
          net.bridge.bridge-nf-call-ip6tables = 1

    - name: Apply sysctl parameters
      command: sysctl --system
      changed_when: false

    - name: Disable swap
      command: swapoff -a
      changed_when: false

    - name: Remove swap from fstab
      replace:
        path: /etc/fstab
        regexp: '^([^#].*?\sswap\s+sw\s+.*)$'
        replace: '# \1'

    - name: Ensure RKE2 config directory exists
      file:
        path: /etc/rancher/rke2
        state: directory
        mode: '0755'

    - name: Create ECR credential refresh script
      copy:
        dest: /usr/local/bin/ecr-login.sh
        content: |
          #!/bin/bash
          LOG="/var/log/ecr-login.log"
          log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG"; }

          log "=== ecr-login.sh starting ==="

          REGION="{{ region }}"
          ACCOUNT=$(aws sts get-caller-identity --query Account --output text 2>&1)
          if [ $? -ne 0 ]; then
            log "ERROR: aws sts get-caller-identity failed: $ACCOUNT"
            exit 1
          fi
          log "AWS account: $ACCOUNT"

          REGISTRY="$ACCOUNT.dkr.ecr.$REGION.amazonaws.com"
          TOKEN=$(aws ecr get-login-password --region "$REGION" 2>/dev/null)
          if [ $? -ne 0 ] || [ -z "$TOKEN" ]; then
            log "ERROR: aws ecr get-login-password failed"
            exit 1
          fi
          log "ECR token obtained for $REGISTRY"

          MIRROR="{{ registry_mirror | default('') }}"
          if [ -n "$MIRROR" ]; then
            cat > /etc/rancher/rke2/registries.yaml <<EOF
          mirrors:
            "docker.io":
              endpoint:
                - "https://$MIRROR"
          configs:
            "$REGISTRY":
              auth:
                username: AWS
                password: "$TOKEN"
          EOF
          else
            cat > /etc/rancher/rke2/registries.yaml <<EOF
          configs:
            "$REGISTRY":
              auth:
                username: AWS
                password: "$TOKEN"
          EOF
          fi
          log "Base registries.yaml written (ECR)"

          DH_ARN="{{ dockerhub_secret_arn | default('') }}"
          if [ -n "$DH_ARN" ]; then
            log "Docker Hub secret ARN configured: $DH_ARN"
            DH_JSON=""
            for attempt in 1 2 3; do
              DH_JSON=$(aws secretsmanager get-secret-value \
                --secret-id "$DH_ARN" \
                --region "$REGION" \
                --query SecretString --output text 2>&1)
              if [ $? -eq 0 ] && [ -n "$DH_JSON" ]; then
                break
              fi
              log "WARNING: Secrets Manager fetch attempt $attempt failed: $DH_JSON"
              DH_JSON=""
              sleep 5
            done

            if [ -z "$DH_JSON" ]; then
              log "ERROR: Could not fetch Docker Hub secret after 3 attempts"
            else
              log "Docker Hub secret fetched from Secrets Manager"
              DH_USER=$(echo "$DH_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin)['user'])" 2>&1)
              PY_RC=$?
              DH_TOKEN=$(echo "$DH_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin)['token'])" 2>&1)
              PY2_RC=$?

              if [ $PY_RC -ne 0 ] || [ -z "$DH_USER" ]; then
                log "ERROR: Failed to parse 'user' from secret JSON (rc=$PY_RC): $DH_USER"
              elif [ $PY2_RC -ne 0 ] || [ -z "$DH_TOKEN" ]; then
                log "ERROR: Failed to parse 'token' from secret JSON (rc=$PY2_RC)"
              else
                log "Docker Hub user: $DH_USER — validating credentials..."
                CURL_OUT=$(curl -sf -u "$DH_USER:$DH_TOKEN" \
                  "https://auth.docker.io/token?service=registry.docker.io&scope=repository:rancher/rke2-runtime:pull" 2>&1)
                CURL_RC=$?
                if [ $CURL_RC -ne 0 ]; then
                  log "WARNING: Docker Hub credential validation failed (rc=$CURL_RC): $CURL_OUT"
                  log "Skipping Docker Hub auth to avoid breaking image pulls"
                else
                  cat >> /etc/rancher/rke2/registries.yaml <<EOF
            "docker.io":
              auth:
                username: "$DH_USER"
                password: "$DH_TOKEN"
          EOF
                  log "Docker Hub credentials validated and added to registries.yaml"
                fi
              fi
            fi
          else
            log "No Docker Hub secret ARN configured — skipping"
          fi

          chmod 600 /etc/rancher/rke2/registries.yaml
          log "registries.yaml keys: $(grep -E '^\s{2}\S' /etc/rancher/rke2/registries.yaml | tr -d ' \":')"
          log "=== ecr-login.sh complete ==="
        mode: '0755'

    - name: Run ECR login script initially
      command: /usr/local/bin/ecr-login.sh
      register: ecr_login_result

    - name: Show ECR login script output
      debug:
        var: ecr_login_result.stdout_lines

    - name: Add ECR credential refresh cron job (runs every 6 hours)
      cron:
        name: "Refresh ECR credentials"
        minute: "0"
        hour: "*/6"
        job: "/usr/local/bin/ecr-login.sh >> /var/log/ecr-login.log 2>&1"
        user: root

    - name: Fetch RKE2 token from Secrets Manager via boto3 (no awscli)
      shell: |
        python3 - <<'PY'
        import boto3
        import sys
        client = boto3.client('secretsmanager', region_name='{{ region }}')
        print(client.get_secret_value(SecretId='{{ cluster_name }}-rke2-token')['SecretString'])
        PY
      register: rke2_token
      changed_when: false

    - name: Get EC2 instance ID from metadata (IMDSv2)
      shell: |
        TOKEN=$(curl -sX PUT "http://169.254.169.254/latest/api/token" -H "X-aws-ec2-metadata-token-ttl-seconds: 60")
        curl -s -H "X-aws-ec2-metadata-token: $TOKEN" http://169.254.169.254/latest/meta-data/instance-id
      register: ec2_instance_id

    - name: Get EC2 availability zone from metadata (IMDSv2)
      shell: |
        TOKEN=$(curl -sX PUT "http://169.254.169.254/latest/api/token" -H "X-aws-ec2-metadata-token-ttl-seconds: 60")
        curl -s -H "X-aws-ec2-metadata-token: $TOKEN" http://169.254.169.254/latest/meta-data/placement/availability-zone
      register: ec2_az

    - name: Write RKE2 agent config
      copy:
        dest: /etc/rancher/rke2/config.yaml
        content: |
          token: {{ rke2_token.stdout | trim }}
          server: https://ip-{{ server_endpoint | replace('.', '-') }}.{{ region }}.compute.internal:9345
          kubelet-arg:
            - "provider-id=aws:///{{ ec2_az.stdout }}/{{ ec2_instance_id.stdout }}"
        mode: '0600'

    - name: Enable and start rke2-agent
      systemd:
        name: rke2-agent
        enabled: yes
        state: started
        daemon_reload: yes

  handlers:
    - name: reload systemd
      systemd:
        daemon_reload: yes 